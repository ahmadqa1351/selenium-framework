<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    REGRESSION TEST SUITE — nightly full regression run.
    Run: mvn test -P regression -Denv=qa -Dbrowser=chrome
-->
<suite name="Enterprise Selenium Framework — Regression Suite"
       parallel="classes"
       thread-count="3"
       verbose="1"
       preserve-order="false">

    <listeners>
        <listener class-name="com.enterprise.framework.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <test name="Login Regression">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.enterprise.framework.tests.smoke.LoginSmokeTest"/>
            <class name="com.enterprise.framework.tests.regression.LoginRegressionTest"/>
        </classes>
    </test>

    <test name="User Management Regression">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.enterprise.framework.tests.regression.UserManagementTest"/>
        </classes>
    </test>

</suite>

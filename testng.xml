<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    DEFAULT TESTNG SUITE — sequential execution, all groups.
    Run: mvn test -DsuiteXmlFile=testng.xml -Denv=qa -Dbrowser=chrome

    Structure:
    ┌─ Suite: Enterprise Selenium Framework
    │   ├─ Test: Smoke Tests
    │   └─ Test: Regression Tests
    └─ Listeners: TestListener (reporting + retry + screenshots)
-->
<suite name="Enterprise Selenium Framework — Full Suite"
       verbose="1"
       preserve-order="true">

    <!-- Global listener registration: applies to every test in this suite -->
    <listeners>
        <listener class-name="com.enterprise.framework.listeners.TestListener"/>
    </listeners>

    <!-- Global parameters: can be overridden by -D JVM flags -->
    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <!-- ── Smoke Gate: runs first. If smoke fails, regression is meaningless ── -->
    <test name="Smoke Tests" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.enterprise.framework.tests.smoke"/>
        </packages>
    </test>

    <!-- ── Full Regression ── -->
    <test name="Regression Tests" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.enterprise.framework.tests.regression"/>
        </packages>
    </test>

</suite>

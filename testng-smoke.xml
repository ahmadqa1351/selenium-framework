<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    SMOKE TEST SUITE — CI gate after every deployment.
    Run: mvn test -P smoke -Denv=qa
    Target: < 5 minutes execution time.
-->
<suite name="Enterprise Selenium Framework — Smoke Suite"
       verbose="1"
       preserve-order="true">

    <listeners>
        <listener class-name="com.enterprise.framework.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.enterprise.framework.tests.smoke"/>
        </packages>
    </test>

</suite>

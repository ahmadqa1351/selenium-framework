<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    PARALLEL EXECUTION SUITE
    Run: mvn test -P parallel -Denv=qa -Dbrowser=chrome

    parallel="methods" means each @Test method runs in its own thread.
    thread-count="4" means 4 concurrent browsers.

    PREREQUISITES:
    - Selenium Grid must be running (set grid.url in config), OR
    - Machine must support the configured thread count of browser instances.

    THREAD SAFETY GUARANTEE:
    - DriverManager uses ThreadLocal → each thread gets its own WebDriver.
    - ExtentReportManager uses ThreadLocal ExtentTest → parallel-safe logging.
    - No static WebDriver fields anywhere in the framework.
-->
<suite name="Enterprise Selenium Framework — Parallel Execution"
       parallel="methods"
       thread-count="4"
       data-provider-thread-count="4"
       verbose="1">

    <listeners>
        <listener class-name="com.enterprise.framework.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <!-- ── Smoke: parallel ── -->
    <test name="Smoke Tests (Parallel)"
          parallel="methods"
          thread-count="4">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.enterprise.framework.tests.smoke"/>
        </packages>
    </test>

    <!-- ── Regression: parallel ── -->
    <test name="Regression Tests (Parallel)"
          parallel="methods"
          thread-count="4">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="data-driven"/>  <!-- data-driven tests can conflict in parallel -->
            </run>
        </groups>
        <packages>
            <package name="com.enterprise.framework.tests.regression"/>
        </packages>
    </test>

</suite>
